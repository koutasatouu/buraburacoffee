---
/* index.astro */
import Layout from '../layouts/Layout.astro';
import LoadingScreen from '../components/LoadingScreen.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import AboutUs from '../components/AboutUs.astro';
import FeaturedMenu from '../components/FeaturedMenu.astro';
import ExperienceGallery from '../components/ExperienceGallery.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import LocationSection from '../components/LocationSection.astro';
import Testimonials from '../components/Testimonials.astro';
import CTASection from '../components/CTASection.astro';
import Footer from '../components/Footer.astro';
---

<Layout 
  title="Bura Bura Coffee | Redefining Coffee Culture - Kopi Tanpa Gula Premium Yogyakarta" 
  description="Bura Bura Coffee - Redefining coffee culture by making sugar-less coffee enjoyable, accessible, and loved by everyone. Kunjungi cabang kami di Cokroaminoto & Mangkubumi, Yogyakarta."
>
  <!-- Loading Animation Overlay -->
  <LoadingScreen />

  <!-- Navigation Bar -->
  <Navbar />

  <!-- Main Content Layout -->
  <main>
    <!-- Hero Section -->
    <Hero />

    <!-- About Us Section -->
    <AboutUs />

    <!-- Menu Showcase Section -->
    <FeaturedMenu />

    <!-- Space & Craft Gallery Section -->
    <ExperienceGallery />

    <!-- Why Choose Us Grid -->
    <WhyChooseUs />

    <!-- Interactive Location Section -->
    <LocationSection />

    <!-- Customer Reviews Section -->
    <Testimonials />

    <!-- Call to Action Card Section -->
    <CTASection />
  </main>

  <!-- Complete Footer -->
  <Footer />
</Layout>
