---
/* LoadingScreen.astro */
---

<div id="loading-screen" class="loading-container">
  <div class="loading-content">
    <div class="logo-wrapper">
      <svg viewBox="0 0 44 24" class="logo-svg" xmlns="http://www.w3.org/2000/svg" fill-rule="evenodd" clip-rule="evenodd">
        <!-- Left Rectangle with two cut-out dots -->
        <path d="M 0,4 C 0,1.8 1.8,0 4,0 h 12 c 2.2,0 4,1.8 4,4 v 16 c 0,2.2 -1.8,4 -4,4 H 4 C 1.8,24 0,22.2 0,20 V 4 Z M 10,9.5 C 11.38,9.5 12.5,8.38 12.5,7 C 12.5,5.62 11.38,4.5 10,4.5 C 8.62,4.5 7.5,5.62 7.5,7 C 7.5,8.38 8.62,9.5 10,9.5 Z M 10,19.5 C 11.38,19.5 12.5,18.38 12.5,17 C 12.5,15.62 11.38,14.5 10,14.5 C 8.62,14.5 7.5,15.62 7.5,17 C 7.5,18.38 8.62,19.5 10,19.5 Z" fill="currentColor"/>
        <!-- Right Rectangle with two cut-out dots -->
        <path d="M 24,4 C 24,1.8 25.8,0 28,0 h 12 c 2.2,0 4,1.8 4,4 v 16 c 0,2.2 -1.8,4 -4,4 H 28 C 25.8,24 24,22.2 24,20 V 4 Z M 34,9.5 C 35.38,9.5 36.5,8.38 36.5,7 C 36.5,5.62 35.38,4.5 34,4.5 C 32.62,4.5 31.5,5.62 31.5,7 C 31.5,8.38 32.62,9.5 34,9.5 Z M 34,19.5 C 35.38,19.5 36.5,18.38 36.5,17 C 36.5,15.62 35.38,14.5 34,14.5 C 32.62,14.5 31.5,15.62 31.5,17 C 31.5,18.38 32.62,19.5 34,19.5 Z" fill="currentColor"/>
      </svg>
    </div>
    <h1 class="brand-text">BURA BURA</h1>
    <span class="sub-text">COFFEE CLUB</span>
  </div>
</div>

<style>
  .loading-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--color-bg-dark);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    opacity: 1;
    transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .loading-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .logo-wrapper {
    width: 70px;
    color: var(--color-blue-primary);
    margin-bottom: 1.5rem;
    animation: logoPulse 1.8s ease-in-out infinite;
  }

  .logo-svg {
    width: 100%;
    height: auto;
  }

  .brand-text {
    font-family: var(--font-heading);
    font-size: 2.2rem;
    font-weight: 800;
    letter-spacing: 0.2em;
    color: #ffffff;
    margin-bottom: 0.25rem;
    animation: textSpacing 1.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .sub-text {
    font-family: var(--font-subheading);
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.4em;
    color: var(--color-blue-light);
    opacity: 0;
    animation: fadeIn 1s ease-out 0.5s forwards;
  }

  @keyframes logoPulse {
    0%, 100% {
      transform: scale(1);
      filter: drop-shadow(0 0 5px rgba(26, 63, 226, 0.2));
    }
    50% {
      transform: scale(1.08);
      filter: drop-shadow(0 0 20px rgba(26, 63, 226, 0.6));
    }
  }

  @keyframes textSpacing {
    from {
      letter-spacing: 0.05em;
      opacity: 0;
    }
    to {
      letter-spacing: 0.2em;
      opacity: 1;
    }
  }

  @keyframes fadeIn {
    to {
      opacity: 0.7;
    }
  }
</style>
