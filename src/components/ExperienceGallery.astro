---
/* ExperienceGallery.astro */
interface Props {
  lang?: string;
}

const { lang = "id" } = Astro.props;
---

<section id="gallery" class="section section-concrete">
  <div class="container">
    <!-- Header -->
    <div class="gallery-header reveal">
      <span class="badge"
        >{lang === "id" ? "Cafe Experience" : "Space Experience"}</span
      >
      <h2 class="section-title">
        {
          lang === "id" ? (
            <>
              Ruang yang Tenang,{" "}
              <>
                <br />
                <span class="text-gradient-blue">Suasana yang Hidup</span>
              </>
            </>
          ) : (
            <>
              A Quiet Space,{" "}
              <>
                <br />
                <span class="text-gradient-blue">A Vibrant Atmosphere</span>
              </>
            </>
          )
        }
      </h2>
      <p class="section-subtitle">
        {
          lang === "id"
            ? "Desain minimalis industrial kami dirancang khusus untuk meminimalkan gangguan visual, membantu Anda fokus menikmati cita rasa kopi murni atau menyelesaikan pekerjaan kreatif Anda."
            : "Our minimalist industrial design is intentionally crafted to minimize visual clutter, helping you focus on enjoying pure coffee flavor or completing your creative work."
        }
      </p>
    </div>

    <!-- Bento Grid Gallery -->
    <div class="bento-grid">
      <!-- Item 1: Ambience (Large Feature) -->
      <div class="bento-item bento-large reveal">
        <img
          src="/cafe1.jpg"
          alt="Suasana Interior Industrial Minimalis Bura Bura Coffee"
          class="bento-img"
          loading="lazy"
        />
        <div class="bento-overlay">
          <div class="bento-text">
            <span class="bento-tag">{lang === "id" ? "Interior" : "Space"}</span
            >
            <h3 class="bento-title">
              {
                lang === "id"
                  ? "Ruang Industrial Minimalis"
                  : "Minimalist Industrial Space"
              }
            </h3>
            <p class="bento-desc">
              {
                lang === "id"
                  ? "Dinding semen ekspos, pencahayaan alami, dan ruang lapang untuk kenyamanan pikiran Anda."
                  : "Exposed concrete walls, natural lighting, and open layout for your peace of mind."
              }
            </p>
          </div>
        </div>
      </div>

      <!-- Item 2: Coffee Craft (Tall Feature) -->
      <div class="bento-item bento-tall reveal reveal-delay-1">
        <img
          src="/barista1.jpg"
          alt="Proses Brewing Kopi Spesialti Bura Bura"
          class="bento-img"
          loading="lazy"
        />
        <div class="bento-overlay">
          <div class="bento-text">
            <span class="bento-tag">{lang === "id" ? "Keahlian" : "Craft"}</span
            >
            <h3 class="bento-title">
              {lang === "id" ? "Keahlian Barista" : "Barista Craftsmanship"}
            </h3>
            <p class="bento-desc">
              {
                lang === "id"
                  ? "Setiap cangkir adalah hasil kalibrasi ekstraksi yang cermat."
                  : "Every single cup is the result of meticulous extraction calibration."
              }
            </p>
          </div>
        </div>
      </div>

      <!-- Item 3: Coffee Drink & Details (Square Stack) -->
      <div class="bento-item reveal reveal-delay-2">
        <img
          src="/cafe2.jpg"
          alt={lang === "id" ? "Sajian Kopi Premium Bura Bura" : "Premium Coffee Serving at Bura Bura"}
          class="bento-img"
          loading="lazy"
        />
        <div class="bento-overlay">
          <div class="bento-text">
            <span class="bento-tag">
              {lang === "id" ? "Kopi Signature" : "Signature Coffee"}
            </span>
            <h3 class="bento-title">
              {lang === "id" ? "Dirty Zero Series" : "Dirty Zero Series"}
            </h3>
          </div>
        </div>
      </div>

      <div class="bento-item reveal reveal-delay-2">
        <img
          src="/cafe3.jpg"
          alt={lang === "id" ? "Sudut Estetik Bura Bura Coffee" : "Aesthetic Corner of Bura Bura Coffee"}
          class="bento-img"
          loading="lazy"
        />
        <div class="bento-overlay">
          <div class="bento-text">
            <span class="bento-tag">
              {lang === "id" ? "Sudut Temu" : "Meeting Spot"}
            </span>
            <h3 class="bento-title">
              {lang === "id" ? "Detail Minimalis" : "Minimalist Details"}
            </h3>
          </div>
        </div>
      </div>

      <!-- Item 4: Text Block (Brand Statement) -->
      <div class="bento-item bento-text-card glass-card reveal reveal-delay-3">
        <div class="text-card-content">
          <span class="quote-mark">“</span>
          <p class="brand-quote">
            {
              lang === "id"
                ? "Kopi yang jujur lahir dari keheningan proses. Kami meniadakan keributan rasa tambahan untuk mempertemukan Anda dengan esensi biji kopi yang sebenarnya."
                : "Honest coffee is born from the silence of the process. We eliminate the noise of artificial flavors to reconnect you with the true essence of the bean."
            }
          </p>
          <span class="quote-author">Bura Bura Coffee Club</span>
        </div>
      </div>

      <!-- Item 5: Pastries (Wide Feature) -->
      <div class="bento-item bento-wide reveal reveal-delay-4">
        <img
          src="/pastry.jpg"
          alt="Sajian Pastri Premium di Bura Bura"
          class="bento-img"
          loading="lazy"
        />
        <div class="bento-overlay">
          <div class="bento-text">
            <span class="bento-tag">{lang === "id" ? "Makanan" : "Food"}</span>
            <h3 class="bento-title">
              {
                lang === "id"
                  ? "Pastri Segar Pendamping Kopi"
                  : "Fresh Pastry Pairings"
              }
            </h3>
            <p class="bento-desc">
              {
                lang === "id"
                  ? "Croissant renyah berlapis mentega yang dipanggang segar setiap pagi."
                  : "Buttery, flaky croissants baked fresh in our ovens every morning."
              }
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .gallery-header {
    margin-bottom: 3.5rem;
    max-width: 650px;
  }

  /* Bento Grid Layout */
  .bento-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 240px;
    gap: 1.5rem;
  }

  .bento-item {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
    border: 1px solid rgba(255, 255, 255, 0.05);
    background-color: var(--color-bg-concrete-light);
  }

  .bento-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .bento-item:hover .bento-img {
    transform: scale(1.05);
  }

  /* Overlay Text on Hover */
  .bento-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      to top,
      rgba(8, 9, 13, 0.9) 0%,
      rgba(8, 9, 13, 0.4) 60%,
      rgba(8, 9, 13, 0) 100%
    );
    display: flex;
    align-items: flex-end;
    padding: 1.5rem;
    opacity: 0;
    transition: var(--transition-smooth);
    pointer-events: none;
  }

  .bento-item:hover .bento-overlay {
    opacity: 1;
    pointer-events: all;
  }

  /* For large items, overlay is always semi-visible and gets darker on hover */
  .bento-large .bento-overlay,
  .bento-tall .bento-overlay,
  .bento-wide .bento-overlay {
    opacity: 0.85;
    background: linear-gradient(
      to top,
      rgba(8, 9, 13, 0.85) 0%,
      rgba(8, 9, 13, 0.2) 60%,
      rgba(8, 9, 13, 0) 100%
    );
  }

  .bento-item:hover.bento-large .bento-overlay,
  .bento-item:hover.bento-tall .bento-overlay,
  .bento-item:hover.bento-wide .bento-overlay {
    opacity: 1;
    background: linear-gradient(
      to top,
      rgba(8, 9, 13, 0.95) 0%,
      rgba(8, 9, 13, 0.4) 60%,
      rgba(8, 9, 13, 0) 100%
    );
  }

  .bento-text {
    transform: translateY(15px);
    transition: var(--transition-smooth);
  }

  .bento-item:hover .bento-text {
    transform: translateY(0);
  }

  .bento-large .bento-text,
  .bento-tall .bento-text,
  .bento-wide .bento-text {
    transform: translateY(0);
  }

  .bento-tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    background-color: var(--color-blue-primary);
    color: #ffffff;
    font-family: var(--font-subheading);
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.5rem;
  }

  .bento-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 0.25rem;
  }

  .bento-desc {
    font-size: 0.85rem;
    color: var(--color-text-light-muted);
    line-height: 1.4;
  }

  /* Bento Grid Span Variants */
  .bento-large {
    grid-column: span 2;
    grid-row: span 2;
  }

  .bento-tall {
    grid-column: span 1;
    grid-row: span 2;
  }

  .bento-wide {
    grid-column: span 2;
    grid-row: span 1;
  }

  /* Bento Text Card Custom Style */
  .bento-text-card {
    grid-column: span 2;
    grid-row: span 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: radial-gradient(
      circle at top left,
      var(--color-blue-glow) 0%,
      transparent 70%
    );
  }

  .text-card-content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    height: 100%;
    position: relative;
  }

  .quote-mark {
    font-family: var(--font-heading);
    font-size: 4rem;
    color: var(--color-blue-light);
    line-height: 0;
    position: absolute;
    top: -10px;
    left: -10px;
    opacity: 0.15;
  }

  .brand-quote {
    font-family: var(--font-subheading);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--color-text-light);
    line-height: 1.6;
    margin-bottom: 1rem;
    z-index: 1;
  }

  .quote-author {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-blue-light);
  }

  /* Responsive Adjustments */
  @media (max-width: 1200px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
    }

    .bento-wide {
      grid-column: span 1;
    }
  }

  @media (max-width: 992px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 220px;
    }

    .bento-large {
      grid-column: span 2;
      grid-row: span 2;
    }

    .bento-tall {
      grid-column: span 1;
      grid-row: span 2;
    }
  }

  @media (max-width: 576px) {
    .bento-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 200px;
      gap: 1rem;
    }

    .bento-large,
    .bento-tall,
    .bento-wide,
    .bento-text-card {
      grid-column: span 1;
      grid-row: span 1;
    }

    .bento-text-card {
      padding: 1.5rem;
    }

    .brand-quote {
      font-size: 0.95rem;
    }
  }
</style>
