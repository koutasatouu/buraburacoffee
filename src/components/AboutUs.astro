---
/* AboutUs.astro */
interface Props {
  lang?: string;
}

const { lang = "id" } = Astro.props;
---

<section id="about" class="section section-concrete">
  <div class="container about-container">
    <!-- Left Column: Visual Collage -->
    <div class="about-visual reveal">
      <div class="about-image-container">
        <div class="about-image-wrapper">
          <img
            src="/barista.jpg"
            alt="Proses Pembuatan Kopi Spesialti di Bura Bura Coffee"
            class="about-image"
            loading="lazy"
          />
        </div>
        <!-- Accent Frame overlay -->
        <div class="accent-frame"></div>
      </div>
      <!-- Mini floating stat card -->
      <div class="floating-stat-card glass-card">
        <span class="stat-icon">☕</span>
        <div class="stat-text">
          <span class="stat-value">Sugar-Less</span>
          <span class="stat-desc"
            >{lang === "id" ? "Nikmat & Sehat" : "Enjoyable & Accessible"}</span
          >
        </div>
      </div>
    </div>

    <!-- Right Column: Story Text -->
    <div class="about-content reveal reveal-delay-2">
      <span class="badge">{lang === "id" ? "Tentang Kami" : "About Us"}</span>
      <h2 class="section-title">
        {
          lang === "id" ? (
            <>
              Menolak Manis Buatan,{" "}
              <>
                <br />
                <span class="text-gradient-blue">
                  Merayakan Cita Rasa Murni
                </span>
              </>
            </>
          ) : (
            <>
              Rejecting Artificial Sweetness,{" "}
              <>
                <br />
                <span class="text-gradient-blue">Celebrating Pure Flavor</span>
              </>
            </>
          )
        }
      </h2>
      <p class="story-paragraph highlight">
        "To redefine coffee culture by making sugar-less coffee enjoyable,
        accessible, and loved by everyone."
      </p>

      {
        lang === "id" ? (
          <>
            <p class="story-paragraph">
              Di Bura Bura Coffee, kami percaya bahwa setiap biji kopi memiliki
              cerita rasa tersendiri—aroma buah yang segar, rasa manis madu
              alami, hingga sentuhan cokelat yang pekat. Menambahkan gula
              berlebih sering kali menutupi keindahan rasa asli ini.
            </p>
            <p class="story-paragraph">
              Itulah mengapa kami memelopori budaya kopi tanpa gula tambahan.
              Melalui teknik sangrai yang presisi dan ekstraksi ristretto yang
              dikalibrasi ketat, kami membuktikan bahwa kopi murni bisa
              dinikmati oleh semua orang dengan rasa yang bulat, lembut, dan
              tanpa rasa pahit yang mengganggu.
            </p>
          </>
        ) : (
          <>
            <p class="story-paragraph">
              At Bura Bura Coffee, we believe that every coffee bean tells its
              own flavor story—fresh fruity notes, natural honey sweetness, to
              rich dark chocolate undertones. Adding excessive sugar often masks
              this native beauty.
            </p>
            <p class="story-paragraph">
              That is why we pioneer a sugar-less coffee culture. Through
              precise roasting profiles and strictly calibrated ristretto
              extractions, we prove that pure coffee can be enjoyed by everyone
              with a smooth, well-rounded taste, free of unpleasant bitterness.
            </p>
          </>
        )
      }

      <div class="philosophy-grid">
        <div class="philosophy-item">
          <div class="phil-icon-wrapper">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path
                d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"
              ></path></svg
            >
          </div>
          <div class="phil-details">
            <h3 class="phil-title">
              {lang === "id" ? "Pilihan Lebih Sehat" : "Healthier Choice"}
            </h3>
            <p class="phil-desc">
              {
                lang === "id"
                  ? "Nikmati kafein harian Anda tanpa khawatir akan kalori kosong dan lonjakan gula darah."
                  : "Enjoy your daily caffeine kick without worrying about empty calories or blood sugar spikes."
              }
            </p>
          </div>
        </div>
        <div class="philosophy-item">
          <div class="phil-icon-wrapper">
            <svg
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><circle cx="12" cy="12" r="10"></circle><path
                d="m9.09 9 1-1a3 3 0 0 1 5.91 1 3 3 0 0 1-2.91 3h-.09M12 17h.01"
              ></path></svg
            >
          </div>
          <div class="phil-details">
            <h3 class="phil-title">Ristretto Base</h3>
            <p class="phil-desc">
              {
                lang === "id"
                  ? "Menggunakan potongan ekstraksi ristretto yang lebih manis dan pekat sebagai bahan dasar minuman kami."
                  : "Using sweet and concentrated ristretto extraction cuts as the foundation of our beverages."
              }
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-container {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 5rem;
    align-items: center;
  }

  /* Visual Column */
  .about-visual {
    position: relative;
    display: flex;
    justify-content: flex-start;
  }

  .about-image-container {
    position: relative;
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4/5;
  }

  .about-image-wrapper {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 20px;
    overflow: hidden;
    z-index: 2;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition-smooth);
  }

  .about-image-wrapper:hover .about-image {
    transform: scale(1.03);
  }

  .accent-frame {
    position: absolute;
    top: 20px;
    left: -20px;
    width: 100%;
    height: 100%;
    border: 2px solid var(--color-blue-primary);
    border-radius: 20px;
    z-index: 1;
    pointer-events: none;
    transition: var(--transition-smooth);
  }

  .about-image-container:hover .accent-frame {
    transform: translate(8px, -8px);
    border-color: var(--color-blue-light);
  }

  /* Floating Stat Card */
  .floating-stat-card {
    position: absolute;
    bottom: 30px;
    right: -20px;
    z-index: 3;
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.5rem;
    max-width: 240px;
  }

  .stat-icon {
    font-size: 1.8rem;
  }

  .stat-text {
    display: flex;
    flex-direction: column;
  }

  .stat-value {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: #ffffff;
  }

  .stat-desc {
    font-size: 0.75rem;
    color: var(--color-text-light-muted);
  }

  /* Content Column */
  .about-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .section-title {
    font-size: 3rem;
    line-height: 1.2;
    margin-bottom: 2rem;
    color: #ffffff;
  }

  .story-paragraph {
    color: var(--color-text-light-muted);
    font-size: 1.05rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .story-paragraph.highlight {
    font-family: var(--font-subheading);
    font-size: 1.25rem;
    font-weight: 500;
    font-style: italic;
    color: var(--color-blue-light);
    border-left: 3px solid var(--color-blue-primary);
    padding-left: 1.25rem;
    margin-bottom: 2rem;
    line-height: 1.5;
  }

  /* Philosophy Items */
  .philosophy-grid {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    margin-top: 1.5rem;
    width: 100%;
  }

  .philosophy-item {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .phil-icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 12px;
    background-color: var(--color-blue-glow);
    color: var(--color-blue-light);
    flex-shrink: 0;
  }

  .phil-title {
    font-family: var(--font-subheading);
    font-size: 1.1rem;
    font-weight: 600;
    color: #ffffff;
    margin-bottom: 0.25rem;
  }

  .phil-desc {
    font-size: 0.9rem;
    color: var(--color-text-light-muted);
    line-height: 1.5;
  }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .about-container {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .about-visual {
      justify-content: center;
      margin-bottom: 1.5rem;
    }

    .accent-frame {
      left: 20px;
    }

    .floating-stat-card {
      right: 10%;
    }
  }

  @media (max-width: 576px) {
    .section-title {
      font-size: 2.25rem;
    }

    .floating-stat-card {
      display: none;
    }

    .about-image-wrapper {
      max-width: 320px;
    }

    .accent-frame {
      display: none;
    }
  }
</style>
