---

<section id="menu" class="section section-dark">
  <div class="container">
    <!-- Header -->
    <div class="menu-header reveal">
      <span class="badge">{lang === "id" ? "Daftar Menu" : "Menu List"}</span>
      <h2 class="section-title text-center">
        {
          lang === "id" ? (
            <>
              Menyajikan Kenikmatan{" "}
              <>
                <br />
                <span class="text-gradient-blue">Kopi & Hidangan Pilihan</span>
              </>
            </>
          ) : (
            <>
              Serving Exquisite{" "}
              <>
                <br />
                <span class="text-gradient-blue">Coffee & Baked Goods</span>
              </>
            </>
          )
        }
      </h2>
      <p class="section-subtitle">
        {
          lang === "id"
            ? "Pilihlah cita rasa yang sesuai dengan suasana hati Anda—dari minuman berbasis espresso ristretto khas kami hingga pastri renyah pembuat bahagia."
            : "Choose the flavor that suits your mood—from our signature espresso ristretto-based drinks to crispy, happiness-inducing pastries."
        }
      </p>
    </div>

    <!-- Interactive Navigation Tabs -->
    <div class="menu-tabs-wrapper reveal reveal-delay-1">
      <div class="menu-tabs">
        <div class="tab-indicator"></div>
        <button class="tab-btn active" data-tab="signatures"
          >{lang === "id" ? "Minuman Signature" : "Signature Drinks"}</button
        >
        <button class="tab-btn" data-tab="full-menu"
          >{lang === "id" ? "Menu Lengkap" : "Complete Menu"}</button
        >
      </div>
    </div>

    <!-- Tab 1: Signatures Grid -->
    <div class="tab-content active" id="tab-signatures">
      <div class="signatures-grid">
        {
          signatures.map((item, index) => (
            <div
              class={`signature-card glass-card reveal reveal-delay-${index + 1}`}
            >
              <div class="card-image-container">
                <img
                  src={item.image}
                  alt={item.name}
                  class="card-image"
                  loading="lazy"
                />
                <span class="card-badge">
                  {lang === "id" ? item.tagId : item.tagEn}
                </span>
              </div>
              <div class="card-info">
                <div class="card-header-row">
                  <h3 class="card-name">{item.name}</h3>
                  <span class="card-price">{item.price}</span>
                </div>
                <p class="card-description">
                  {lang === "id" ? item.descriptionId : item.descriptionEn}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <!-- Tab 2: Full Menu Visual Boards -->
    <div class="tab-content" id="tab-full-menu">
      <div class="full-menu-boards">
        <!-- Blue Board: Espresso & Non-Coffee (Matches physical menu style) -->
        <div class="menu-board blue-board">
          <div class="board-brand-header">
            <svg
              class="board-logo"
              viewBox="0 0 44 24"
              xmlns="http://www.w3.org/2000/svg"
              fill="none"
