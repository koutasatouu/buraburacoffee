---
/* Footer.astro */
interface Props {
  lang?: string;
}

const { lang = "id" } = Astro.props;
const currentYear = new Date().getFullYear();
---

<footer class="footer-section">
  <div class="container footer-container">
    <!-- Brand Info -->
    <div class="footer-brand reveal">
      <div class="footer-logo">
        <svg
          viewBox="0 0 44 24"
          xmlns="http://www.w3.org/2000/svg"
          fill-rule="evenodd"
          clip-rule="evenodd"
        >
          <path
            d="M 0,4 C 0,1.8 1.8,0 4,0 h 12 c 2.2,0 4,1.8 4,4 v 16 c 0,2.2 -1.8,4 -4,4 H 4 C 1.8,24 0,22.2 0,20 V 4 Z M 10,9.5 C 11.38,9.5 12.5,8.38 12.5,7 C 12.5,5.62 11.38,4.5 10,4.5 C 8.62,4.5 7.5,5.62 7.5,7 C 7.5,8.38 8.62,9.5 10,9.5 Z M 10,19.5 C 11.38,19.5 12.5,18.38 12.5,17 C 12.5,15.62 11.38,14.5 10,14.5 C 8.62,14.5 7.5,15.62 7.5,17 C 7.5,18.38 8.62,19.5 10,19.5 Z"
            fill="currentColor"></path>
          <path
            d="M 24,4 C 24,1.8 25.8,0 28,0 h 12 c 2.2,0 4,1.8 4,4 v 16 c 0,2.2 -1.8,4 -4,4 H 28 C 25.8,24 24,22.2 24,20 V 4 Z M 34,9.5 C 35.38,9.5 36.5,8.38 36.5,7 C 36.5,5.62 35.38,4.5 34,4.5 C 32.62,4.5 31.5,5.62 31.5,7 C 31.5,8.38 32.62,9.5 34,9.5 Z M 34,19.5 C 35.38,19.5 36.5,18.38 36.5,17 C 36.5,15.62 35.38,14.5 34,14.5 C 32.62,14.5 31.5,15.62 31.5,17 C 31.5,18.38 32.62,19.5 34,19.5 Z"
            fill="currentColor"></path>
        </svg>
        <span class="logo-text">BURA BURA</span>
      </div>
      <p class="brand-tagline">
        To redefine coffee culture by making sugar-less coffee enjoyable,
        accessible, and loved by everyone.
      </p>
      <!-- Social Media Icons -->
      <div class="social-links">
        <a
          href="https://instagram.com/buraburacoffee"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon-link"
          aria-label="Instagram"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
              x1="17.5"
              y1="6.5"
              x2="17.51"
              y2="6.5"></line></svg
          >
        </a>
        <a
          href="https://linktr.ee/buraburacoffeeclub"
          target="_blank"
          rel="noopener noreferrer"
          class="social-icon-link"
          aria-label="Linktree"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            ><path
              d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"
            ></path><path
              d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"
            ></path></svg
          >
        </a>
      </div>
    </div>

    <!-- Quick Navigation -->
    <div class="footer-links reveal reveal-delay-1">
      <h3 class="footer-title">{lang === "id" ? "Navigasi" : "Navigation"}</h3>
      <ul class="link-list">
        <li><a href={lang === "en" ? "/" : "/id"}>Home</a></li>
        <li>
          <a href="#about">{lang === "id" ? "Tentang Kami" : "About Us"}</a>
        </li>
        <li><a href="#menu">Daftar Menu</a></li>
        <li><a href="#gallery">Cafe Experience</a></li>
        <li>
          <a href="#location"
            >{lang === "id" ? "Lokasi & Kontak" : "Location & Contact"}</a
          >
        </li>
      </ul>
    </div>

    <!-- Operating Hours -->
    <div class="footer-hours reveal reveal-delay-2">
      <h3 class="footer-title">
        {lang === "id" ? "Jam Buka" : "Opening Hours"}
      </h3>
      <ul class="hours-list">
        <li>
          <span class="day">Cokroaminoto:</span>
          <span class="time">08.00 - 23.00 WIB</span>
        </li>
        <li>
          <span class="day">Mangkubumi:</span>
          <span class="time">09.00 - 24.00 WIB</span>
        </li>
        <li class="hours-note">
          {
            lang === "id"
              ? "Buka setiap hari, termasuk hari libur nasional."
              : "Open daily, including national holidays."
          }
        </li>
      </ul>
    </div>

    <!-- Contact & Address -->
    <div class="footer-contact reveal reveal-delay-3">
      <h3 class="footer-title">
        {lang === "id" ? "Kontak & Alamat" : "Contact & Address"}
      </h3>
      <ul class="contact-list">
        <li>
          <svg
            class="contact-icon"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.94.725l.548 2.2a1.3 1.3 0 01-.321 1.25L7.7 9.35a16 16 0 006.95 6.95l1.63-1.63a1.3 1.3 0 011.25-.321l2.2.548a1.3 1.3 0 01.725.94V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path></svg
          >
          <span>+62 812-3456-7890</span>
        </li>
        <li>
          <svg
            class="contact-icon"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path></svg
          >
          <span>buraburacoffee@gmail.com</span>
        </li>
        <li>
          <svg
            class="contact-icon"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
            ></path><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
          >
          <span class="addr-detail"
            >Ruko Cokro Square, Jl. HOS Cokroaminoto, Yogyakarta</span
          >
        </li>
      </ul>
    </div>
  </div>

  <!-- Copyright Bar -->
  <div class="footer-bottom">
    <div class="container bottom-container">
      <p class="copyright">
        &copy; {currentYear} Bura Bura Coffee. All Rights Reserved.
      </p>
      <p class="designer">
        {lang === "id" ? "Didesain oleh" : "Designed by"}{" "}
        <span class="designer-name">Antigravity Agent</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-section {
    background-color: #050608;
    color: var(--color-text-light-muted);
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    padding-top: 5rem;
    position: relative;
    z-index: 10;
  }

  .footer-container {
    display: grid;
    grid-template-columns: 1.3fr 0.8fr 1fr 1.1fr;
    gap: 3.5rem;
    padding-bottom: 4rem;
  }

  /* Brand Column */
  .footer-brand {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #ffffff;
    font-weight: 800;
  }

  .footer-logo svg {
    width: 32px;
    color: var(--color-blue-primary);
  }

  .logo-text {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    letter-spacing: 0.1em;
  }

  .brand-tagline {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-text-light-muted);
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-icon-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: #12141c;
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: var(--color-text-light-muted);
    transition: var(--transition-fast);
  }

  .social-icon-link:hover {
    color: #ffffff;
    background-color: var(--color-blue-primary);
    border-color: var(--color-blue-primary);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px var(--color-blue-glow-strong);
  }

  /* Common Footer Title */
  .footer-title {
    font-family: var(--font-subheading);
    font-size: 1rem;
    font-weight: 700;
    color: #ffffff;
    margin-bottom: 1.75rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  /* Link list styles */
  .link-list,
  .hours-list,
  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    font-size: 0.9rem;
  }

  .link-list a {
    color: var(--color-text-light-muted);
    transition: var(--transition-fast);
  }

  .link-list a:hover {
    color: #ffffff;
    padding-left: 4px;
  }

  /* Hours List styles */
  .hours-list li {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .day {
    font-weight: 600;
    color: #ffffff;
  }

  .time {
    color: var(--color-blue-light);
  }

  .hours-note {
    font-size: 0.78rem;
    opacity: 0.6;
    line-height: 1.4;
    border-top: 1px solid rgba(255, 255, 255, 0.05);
    padding-top: 0.75rem;
    margin-top: 0.5rem;
  }

  /* Contact List styles */
  .contact-list li {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
  }

  .contact-icon {
    width: 18px;
    height: 18px;
    color: var(--color-blue-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .addr-detail {
    line-height: 1.5;
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255, 255, 255, 0.03);
    padding: 2rem 0;
    font-size: 0.8rem;
  }

  .bottom-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .designer-name {
    color: var(--color-blue-light);
    font-weight: 600;
  }

  /* Responsive Adjustments */
  @media (max-width: 1200px) {
    .footer-container {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem;
    }
  }

  @media (max-width: 768px) {
    .footer-section {
      padding-top: 3.5rem;
    }

    .footer-container {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .bottom-container {
      flex-direction: column;
      gap: 0.75rem;
      text-align: center;
    }
  }
</style>
