---
/* CTASection.astro */
---

<section id="contact" class="section section-concrete">
  <div class="container">
    <div class="cta-card reveal">
      <!-- Background glowing orb -->
      <div class="cta-glow"></div>

      <div class="cta-content">
        <span class="badge">Kunjungi Kami</span>
        <h2 class="cta-title">Siap Merasakan <br/>Kopi Murni Tanpa Gula?</h2>
        <p class="cta-desc">
          Lepaskan penat, temukan kembali esensi kopi yang sesungguhnya, dan nikmati momen produktif atau santai Anda di Bura Bura Coffee Yogyakarta. Kami menanti kehadiran Anda hari ini.
        </p>
        
        <div class="cta-actions">
          <a href="https://wa.me/6281234567890?text=Halo%20Bura%20Bura%20Coffee,%20saya%20ingin%20tanya%20reservasi" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-cta-light">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            Tanya Reservasi via WA
          </a>
          <a href="https://instagram.com/buraburacoffee" target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            Ikuti Instagram Kami
          </a>
        </div>
      </div>

      <!-- Secondary graphic / visual overlay -->
      <div class="cta-graphic">
        <svg class="cta-logo-bg" viewBox="0 0 44 24" xmlns="http://www.w3.org/2000/svg" fill="none">
          <path d="M 0,4 C 0,1.8 1.8,0 4,0 h 12 c 2.2,0 4,1.8 4,4 v 16 c 0,2.2 -1.8,4 -4,4 H 4 C 1.8,24 0,22.2 0,20 V 4 Z M 10,9.5 C 11.38,9.5 12.5,8.38 12.5,7 C 12.5,5.62 11.38,4.5 10,4.5 C 8.62,4.5 7.5,5.62 7.5,7 C 7.5,8.38 8.62,9.5 10,9.5 Z M 10,19.5 C 11.38,19.5 12.5,18.38 12.5,17 C 12.5,15.62 11.38,14.5 10,14.5 C 8.62,14.5 7.5,15.62 7.5,17 C 7.5,18.38 8.62,19.5 10,19.5 Z" fill="currentColor"/>
          <path d="M 24,4 C 24,1.8 25.8,0 28,0 h 12 c 2.2,0 4,1.8 4,4 v 16 c 0,2.2 -1.8,4 -4,4 H 28 C 25.8,24 24,22.2 24,20 V 4 Z M 34,9.5 C 35.38,9.5 36.5,8.38 36.5,7 C 36.5,5.62 35.38,4.5 34,4.5 C 32.62,4.5 31.5,5.62 31.5,7 C 31.5,8.38 32.62,9.5 34,9.5 Z M 34,19.5 C 35.38,19.5 36.5,18.38 36.5,17 C 36.5,15.62 35.38,14.5 34,14.5 C 32.62,14.5 31.5,15.62 31.5,17 C 31.5,18.38 32.62,19.5 34,19.5 Z" fill="currentColor"/>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-card {
    background: linear-gradient(135deg, var(--color-blue-dark) 0%, var(--color-blue-primary) 100%);
    border-radius: 32px;
    padding: 5rem;
    position: relative;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: center;
    box-shadow: 0 30px 60px rgba(26, 63, 226, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .cta-glow {
    position: absolute;
    bottom: -50%;
    right: -20%;
    width: 60%;
    height: 100%;
    background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, rgba(26, 63, 226, 0) 75%);
    pointer-events: none;
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    position: relative;
    z-index: 2;
  }

  .cta-title {
    font-size: 3rem;
    font-weight: 800;
    line-height: 1.15;
    color: #ffffff;
    margin-bottom: 1.5rem;
  }

  .cta-desc {
    font-size: 1.05rem;
    color: rgba(255, 255, 255, 0.8);
    line-height: 1.6;
    margin-bottom: 2.5rem;
    max-width: 500px;
  }

  .cta-actions {
    display: flex;
    gap: 1.25rem;
  }

  .btn-cta-light {
    background-color: #ffffff;
    color: var(--color-blue-primary);
    border-color: #ffffff;
    box-shadow: 0 8px 24px rgba(255, 255, 255, 0.15);
  }

  .btn-cta-light:hover {
    background-color: var(--color-bg-dark);
    color: #ffffff;
    border-color: var(--color-bg-dark);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  /* Logo Graphic background */
  .cta-graphic {
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .cta-logo-bg {
    width: 240px;
    color: #ffffff;
    opacity: 0.05;
    transition: var(--transition-smooth);
    animation: pulseGlow 8s ease-in-out infinite alternate;
  }

  .cta-card:hover .cta-logo-bg {
    opacity: 0.08;
    transform: scale(1.05);
  }

  /* Responsive Adjustments */
  @media (max-width: 992px) {
    .cta-card {
      grid-template-columns: 1fr;
      padding: 3.5rem;
      gap: 2rem;
      text-align: center;
    }

    .cta-content {
      align-items: center;
    }

    .cta-desc {
      margin-left: auto;
      margin-right: auto;
    }

    .cta-actions {
      justify-content: center;
      width: 100%;
    }

    .cta-graphic {
      display: none;
    }
  }

  @media (max-width: 576px) {
    .cta-card {
      padding: 2.25rem 1.5rem;
      border-radius: 24px;
    }

    .cta-title {
      font-size: 2.25rem;
    }

    .cta-actions {
      flex-direction: column;
      gap: 1rem;
    }

    .btn {
      width: 100%;
    }
  }
</style>
